    flint_mpn_mulhigh_n(t, s, x4 + 5, 4);
    t[4] = mpn_addmul_1(t, x3 + 6, 4, exp_series_cs[15]);
    t[4] += mpn_addmul_1(t, x2 + 6, 4, exp_series_cs[14]);
    t[5] = mpn_addmul_1(t, x + 6, 5, exp_series_cs[13]);
    t[5] += exp_series_cs[12];
    flint_mpn_mulhigh_n(s, t, x4 + 3, 6);
    s[6] = mpn_addmul_1(s, x3 + 4, 6, exp_series_cs[11]);
    s[6] += mpn_addmul_1(s, x2 + 4, 6, exp_series_cs[10]);
    s[7] = mpn_addmul_1(s, x + 4, 7, exp_series_cs[9]);
    s[7] += exp_series_cs[8];
    flint_mpn_mulhigh_n(t, s, x4 + 1, 8);
    t[8] = mpn_addmul_1(t, x3 + 2, 8, exp_series_cs[7]);
    t[8] += mpn_addmul_1(t, x2 + 2, 8, exp_series_cs[6]);
    t[9] = mpn_addmul_1(t, x + 2, 9, exp_series_cs[5]);
