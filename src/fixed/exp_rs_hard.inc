    umul_ppmm(h3, l3, s, x[1]);         /* x^3 * 2^128 ~= h3 < 2^32 */
    umul_ppmm(h, l, x[1], x[0]);
    t = s + ((h << 1) | (l >> 63));     /* x^2 * 2^128 */
    t = (t >> 1) + h3 / 6;              /* x^2/2 + x^3/6 */
    add_ssaaaa(res[1], res[0], x[1], x[0], 0, t);
    res[2] = 1;
}

