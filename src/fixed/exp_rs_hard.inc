    t[0] = 0;
    t[1] = exp_series_cs[20];
    flint_mpn_mulhigh_n(s, t, x4 + 7, 2);
    s[2] = mpn_addmul_1(s, x3 + 8, 2, exp_series_cs[19]);
    s[2] += mpn_addmul_1(s, x2 + 8, 2, exp_series_cs[18]);
    s[3] = mpn_addmul_1(s, x + 8, 3, exp_series_cs[17]);
