    umul_ppmm(t[1], t[0], x[8], exp_series_cs[17]);
    t[1] += exp_series_cs[16];
    flint_mpn_mulhigh_n(s, t, x4 + 5, 2);
    s[2] = mpn_addmul_1(s, x3 + 6, 2, exp_series_cs[15]);
    s[2] += mpn_addmul_1(s, x2 + 6, 2, exp_series_cs[14]);
    s[3] = mpn_addmul_1(s, x + 6, 3, exp_series_cs[13]);
    s[3] += exp_series_cs[12];
    flint_mpn_mulhigh_n(t, s, x4 + 3, 4);
    t[4] = mpn_addmul_1(t, x3 + 4, 4, exp_series_cs[11]);
    t[4] += mpn_addmul_1(t, x2 + 4, 4, exp_series_cs[10]);
    t[5] = mpn_addmul_1(t, x + 4, 5, exp_series_cs[9]);
    t[5] += exp_series_cs[8];
    flint_mpn_mulhigh_n(s, t, x4 + 1, 6);
    s[6] = mpn_addmul_1(s, x3 + 2, 6, exp_series_cs[7]);
    s[6] += mpn_addmul_1(s, x2 + 2, 6, exp_series_cs[6]);
    s[7] = mpn_addmul_1(s, x + 2, 7, exp_series_cs[5]);
    s[7] += exp_series_cs[4];
    flint_mpn_mulhigh_n(t, s, x4 - 1, 8);
    t[8] = mpn_addmul_1(t, x3, 8, exp_series_cs[3]);

    flint_mpn_mulhigh_n(res, t, exp_series_fac20_inv + 11, 9);

    mpn_rshift(s, x2, 8, 1);
    res[8] += mpn_add_n(res, res, s, 8);
    res[9] = 1 + mpn_add_n(res, res, x, 9);
}

/* res[0..10] ~= sum_{k<20} x^k/k!; x: 10 frac limbs,
