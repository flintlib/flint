/* res[0..11] ~= sum_{k<21} x^k/k!; x: 11 frac limbs,
   0 <= x < 2^-32; one-sided error <= 8 ulp (2^-704) */
static void
_fixed_exp_rs32_21(nn_ptr res, nn_srcptr x)
{
    ulong x2[11];
    ulong x3[10];
    ulong x4p[10];
    ulong s[12];
    ulong t[12];

    nn_ptr x4 = x4p + 1;
