    s[3] = mpn_addmul_1(s, x + 4, 3, exp_series_cs[9]);
    s[3] += exp_series_cs[8];
    flint_mpn_mulhigh_n(t, s, x4 + 1, 4);
    t[4] = mpn_addmul_1(t, x3 + 2, 4, exp_series_cs[7]);
    t[4] += mpn_addmul_1(t, x2 + 2, 4, exp_series_cs[6]);
    t[5] = mpn_addmul_1(t, x + 2, 5, exp_series_cs[5]);
    t[5] += exp_series_cs[4];
    flint_mpn_mulhigh_n(s, t, x4 - 1, 6);
    s[6] = mpn_addmul_1(s, x3, 6, exp_series_cs[3]);

    flint_mpn_mulhigh_n(res, s, exp_series_fac20_inv + 13, 7);

    mpn_rshift(t, x2, 6, 1);
    res[6] += mpn_add_n(res, res, t, 6);
    res[7] = 1 + mpn_add_n(res, res, x, 7);
}

/* res[0..8] ~= sum_{k<16} x^k/k!; x: 8 frac limbs,
   0 <= x < 2^-32; one-sided error <= 8 ulp (2^-512) */
static void
_fixed_exp_rs32_16(nn_ptr res, nn_srcptr x)
{
    ulong x2[8];
    ulong x3[7];
    ulong x4p[7];
    ulong s[9];
    ulong t[9];

    nn_ptr x4 = x4p + 1;
    x4p[0] = 0;

    flint_mpn_sqrhigh(x2, x, 8);
    flint_mpn_mulhigh_n(x3, x + 1, x2, 7);
    flint_mpn_sqrhigh(x4, x2 + 1, 6);

    umul_ppmm(t[1], t[0], x3[6], exp_series_cs[15]);
    t[1] += mpn_addmul_1(t, x2 + 6, 1, exp_series_cs[14]);
    t[2] = mpn_addmul_1(t, x + 6, 2, exp_series_cs[13]);
    t[2] += exp_series_cs[12];
    flint_mpn_mulhigh_n(s, t, x4 + 3, 3);
    s[3] = mpn_addmul_1(s, x3 + 4, 3, exp_series_cs[11]);
    s[3] += mpn_addmul_1(s, x2 + 4, 3, exp_series_cs[10]);
    s[4] = mpn_addmul_1(s, x + 4, 4, exp_series_cs[9]);
    s[4] += exp_series_cs[8];
    flint_mpn_mulhigh_n(t, s, x4 + 1, 5);
    t[5] = mpn_addmul_1(t, x3 + 2, 5, exp_series_cs[7]);
    t[5] += mpn_addmul_1(t, x2 + 2, 5, exp_series_cs[6]);
    t[6] = mpn_addmul_1(t, x + 2, 6, exp_series_cs[5]);
    t[6] += exp_series_cs[4];
    flint_mpn_mulhigh_n(s, t, x4 - 1, 7);
    s[7] = mpn_addmul_1(s, x3, 7, exp_series_cs[3]);

    flint_mpn_mulhigh_n(res, s, exp_series_fac20_inv + 12, 8);

    mpn_rshift(t, x2, 7, 1);
    res[7] += mpn_add_n(res, res, t, 7);
    res[8] = 1 + mpn_add_n(res, res, x, 8);
}

/* res[0..9] ~= sum_{k<18} x^k/k!; x: 9 frac limbs,
   0 <= x < 2^-32; one-sided error <= 8 ulp (2^-576) */
static void
_fixed_exp_rs32_18(nn_ptr res, nn_srcptr x)
